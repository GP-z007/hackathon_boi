# ───── Auth ─────
# REQUIRED. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Never commit a real value. Treat any leaked secret as compromised and rotate.
SECRET_KEY=replace-me-with-a-64-char-hex-secret

# ───── Database ─────
# Local dev (SQLite, ephemeral on Railway):
DATABASE_URL=sqlite+aiosqlite:///./bias_audit.db
# Production on Railway (managed Postgres):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME

# ───── CORS ─────
# Comma-separated list of origins allowed to call the API.
# Production: set to your Vercel URL, e.g. https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000

# ───── Runtime ─────
# `development` enables auto-verify on /auth/register; use `production` in prod.
ENVIRONMENT=development

# ───── Limits ─────
# Maximum CSV upload size in megabytes.
MAX_UPLOAD_SIZE_MB=10

# ───── Storage ─────
# Where uploaded CSVs are persisted for downstream re-analysis. On Railway,
# point this at a Volume mount path (e.g. /data) so files survive restarts.
# DATASET_STORAGE_DIR=uploaded_datasets
