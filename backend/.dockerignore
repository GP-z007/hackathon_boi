# Don't ship local virtualenvs, caches, or DB files into the build context.
# These can easily add 2-3 GB to the build, slowing pushes and bloating layers.

.venv/
venv/
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local databases / runtime artefacts
*.db
*.db-journal
*.sqlite
*.sqlite3
uploaded_datasets/*
!uploaded_datasets/.gitkeep

# Local env files (real secrets must come from the host platform's env panel)
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
.vscode/
.idea/

# CI / docs that don't need to live inside the image
.git/
.gitignore
README.md
DEPLOY.md
